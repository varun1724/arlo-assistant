# Database
POSTGRES_USER=arlo_assistant
POSTGRES_PASSWORD=arlo_assistant_dev
POSTGRES_DB=arlo_assistant
DATABASE_URL=postgresql+asyncpg://arlo_assistant:arlo_assistant_dev@db:5432/arlo_assistant

# API
API_HOST=0.0.0.0
API_PORT=8002
API_KEY=arlo-assistant-dev-key

# JWT Auth
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_ACCESS_EXPIRY_MINUTES=30
JWT_REFRESH_EXPIRY_DAYS=7

# Claude Code CLI
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_COMMAND=claude
CLAUDE_MODEL=sonnet
CLAUDE_TIMEOUT_SECONDS=120

# Arlo Runtime (for kicking off jobs)
# NOTE: inside Docker, "localhost" resolves to this container, not the host.
# Use the runtime's service name on arlo_network. For local dev outside Docker,
# override with http://localhost:8000.
ARLO_RUNTIME_URL=http://arlo-runtime-api-1:8000
ARLO_RUNTIME_TOKEN=change-me-to-a-real-secret

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated allowlist. Do not use "*" — CORS wildcards disable credentials.
CORS_ORIGINS=http://100.75.94.5,http://localhost,http://127.0.0.1

# User timezone (IANA name). Used by reminder/habit/meal date math.
USER_TIMEZONE=America/Los_Angeles

# Weather (optional)
WEATHER_API_KEY=
